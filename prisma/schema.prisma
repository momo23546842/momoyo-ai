generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums (new) ────────────────────────────────────────────

enum ExperienceType {
  INTERNSHIP
  CONTRACT
  EMPLOYMENT
}

enum ExperienceCategory {
  IT
  NUTRITION
  EDU
  OTHER
}

// ─── Existing tables (unchanged) ────────────────────────────

model Profile {
  id          Int      @id @default(autoincrement())
  name        String
  bio         String
  catchphrase String?
  // NEW – nullable so existing rows stay valid
  summary     String?
  focus       String?
  vision      String?
  updatedAt   DateTime @updatedAt
}

model Resume {
  id           Int       @id @default(autoincrement())
  type         String    // "work" | "education"
  title        String
  organization String
  startDate    DateTime
  endDate      DateTime?
  description  String?
  createdAt    DateTime  @default(now())
}

model Skill {
  id       Int    @id @default(autoincrement())
  name     String
  category String
  level    Int
}

model Conversation {
  id        Int      @id @default(autoincrement())
  sessionId String
  role      String
  message   String
  mode      String   // "chat" | "voice"
  createdAt DateTime @default(now())
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model Booking {
  id            Int      @id @default(autoincrement())
  name          String
  email         String
  startTime     DateTime
  endTime       DateTime
  googleEventId String?
  meetLink      String?
  createdAt     DateTime @default(now())
}

model AvailableHours {
  id        Int     @id @default(autoincrement())
  dayOfWeek Int
  startTime String
  endTime   String
  isActive  Boolean @default(true)
}

// ─── New tables ─────────────────────────────────────────────

model Experience {
  id          Int                @id @default(autoincrement())
  type        ExperienceType
  category    ExperienceCategory
  title       String
  org         String
  startDate   DateTime
  endDate     DateTime?
  description String?
  highlights  String[]           // bullet-point achievements
  sortOrder   Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  techStack ExperienceTech[]
}

model TechStack {
  id   Int    @id @default(autoincrement())
  name String @unique // e.g. "Next.js", "Prisma", "MCP"

  experiences ExperienceTech[]
}

model ExperienceTech {
  experienceId Int
  techId       Int

  experience Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  tech       TechStack  @relation(fields: [techId], references: [id], onDelete: Cascade)

  @@id([experienceId, techId])
}

model InterviewQA {
  id        Int      @id @default(autoincrement())
  question  String
  answer    String
  category  String?  // e.g. "behavioural", "technical", "personal"
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}
